# URL publica de la aplicacion. En local puede omitirse.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase. Usa valores locales o ficticios hasta aprobar un proyecto real.
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=example-anon-key
SUPABASE_SERVICE_ROLE_KEY=example-service-role-key

# Google OAuth. Mantener el secreto exclusivamente en el servidor.
GOOGLE_CLIENT_ID=example-google-client-id
GOOGLE_CLIENT_SECRET=example-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# OpenAI. Mantener la clave exclusivamente en el servidor.
OPENAI_API_KEY=example-openai-api-key

# MetaTrader 5. Usar solo una cuenta demo cuando se apruebe la integracion.
MT5_LOGIN=00000000
MT5_PASSWORD=example-demo-password
MT5_SERVER=example-demo-server
